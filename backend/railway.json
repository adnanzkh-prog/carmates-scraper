{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "uvicorn main:app --host 0.0.0.0 --port 8080",
    "healthcheckPath": "/listings?limit=1",
    "healthcheckTimeout": 30
  }
}
